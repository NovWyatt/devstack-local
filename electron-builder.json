{
  "appId": "com.devstack.local",
  "productName": "DevStack Local",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources/binaries",
      "to": "binaries",
      "filter": [
        "**/*",
        "!apache/logs/**",
        "!apache/conf/httpd.devstack.conf",
        "!apache/conf/extra/httpd-devstack-vhosts.conf",
        "!mysql/data/**",
        "!mysql/tmp/**",
        "!php/*/php.ini",
        "!php/*/php.ini.bak",
        "!php/*/backups/**",
        "!php/*/logs/**",
        "!php/*/tmp/**",
        "!php/*/sessions/**"
      ]
    },
    {
      "from": "public/icon.ico",
      "to": "icon.ico"
    }
  ],
  "win": {
    "target": ["nsis"],
    "icon": "public/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  }
}
